# Tutorbox Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# REQUIRED VARIABLES
# ============================================

# Authentication
NEXTAUTH_SECRET=change-this-to-a-random-string-in-production
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=noreply@tutorbox.cc

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/tutorbox

# ============================================
# OPTIONAL VARIABLES (Development)
# ============================================

# Anonymous Trial Duration (defaults to 30 minutes)
NEXT_PUBLIC_ANONYMOUS_TRIAL_MINUTES=30

# Base URL for redirects (used in dev preview mode)
# In production: https://gm.tutorbox.cc
# In development: http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Hostname (defaults to http://localhost:3000)
HOSTNAME=http://localhost:3000

# ============================================
# PADDLE PAYMENT INTEGRATION (Optional)
# ============================================
# These are optional in development. The app will run without them.
# Payment features will show "Pricing coming soon" if not configured.

# Paddle API Credentials
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=

# Paddle Client Token (for frontend)
# NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=

# Paddle Environment (sandbox or production)
# NEXT_PUBLIC_PADDLE_ENV=sandbox

# Paddle Price IDs
# Grammar Master - Chinese pricing
# NEXT_PUBLIC_PADDLE_PRICE_ID_GRAMMAR_YEARLY_CNY=

# Grammar Master - USD pricing
# NEXT_PUBLIC_PADDLE_PRICE_ID_GRAMMAR_YEARLY_USD=

# Lease AI Review - One-time USD
# NEXT_PUBLIC_PADDLE_PRICE_ID_LEASE_ONETIME_USD=

# Cast Master (Broadcast Master) - Yearly CNY
# NEXT_PUBLIC_PADDLE_PRICE_ID_PROMPTER_YEARLY_CNY=

# ============================================
# GOOGLE OAUTH (Currently Disabled)
# ============================================
# Google OAuth is not currently used but can be enabled if needed

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ============================================
# OTHER OPTIONAL VARIABLES
# ============================================

# Project Planner ID
# NEXT_PUBLIC_PROJECT_PLANNER_ID=

# Skip Events Flag
# NEXT_PUBLIC_SKIP_EVENTS=

# ============================================
# PAGE AGENT INTEGRATION (Optional)
# ============================================
# Alibaba's PageAgent - AI assistant for the site
# Uses DashScope (Qwen) for LLM-powered conversations

# DashScope API Key (get from https://dashscope.aliyuncs.com)
# DASHSCOPE_API_KEY=sk_your_api_key_here

# DashScope Model (e.g., qwen-plus-2025-07-28, qwen-turbo, qwen-max)
# DASHSCOPE_MODEL=qwen-plus-2025-07-28

# Optional: Enable/disable PageAgent
# NEXT_PUBLIC_PAGE_AGENT_ENABLED=true
