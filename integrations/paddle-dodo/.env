# App
APP_ENV=dev

# JWT
JWT_SECRET_KEY=change_this_to_a_strong_random_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite:///./app.db

# Paddle（先用占位 / sandbox）
PADDLE_ENV=sandbox
PADDLE_API_KEY=your_test_or_placeholder_key_here
PADDLE_VENDOR_ID=12345
PADDLE_WEBHOOK_SECRET=your_webhook_secret_here

# Example plan price IDs
PADDLE_PRICE_ID_BASIC=price_basic_xxx
PADDLE_PRICE_ID_PRO=price_pro_xxx
