# App
APP_ENV=dev

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite:///./app.db

# Paddle
PADDLE_ENV=sandbox
PADDLE_API_KEY=your_paddle_api_key_here
PADDLE_VENDOR_ID=your_paddle_vendor_id_here  # 可选，看你用的 API 版本
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret_here

# Example plan price IDs
PADDLE_PRICE_ID_BASIC=price_basic_xxx
PADDLE_PRICE_ID_PRO=price_pro_xxx

